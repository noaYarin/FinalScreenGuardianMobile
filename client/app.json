{
  "expo": {
    "name": "ScreenGuardianMobile",
    "slug": "ScreenGuardianMobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icons/icon.png",
    "scheme": "screenguardianmobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "maps",
          "comgooglemaps",
          "waze"
        ]
      }
    },
    "android": {
  "permissions": [
    "PACKAGE_USAGE_STATS",
    "SYSTEM_ALERT_WINDOW",
    "POST_NOTIFICATIONS",
    "QUERY_ALL_PACKAGES",
    "INTERNET"
  ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.screenguardianmobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": {
            "scheme": "geo"
          }
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withFcmAndroid",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icons/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ScreenGuardian to use your location to keep your child safe."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to your photos to set your child's profile picture.",
          "cameraPermission": "Allow camera access to take a photo for your child's profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}